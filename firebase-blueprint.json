{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["CUSTOMER", "ADMIN"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A garment item for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "stock": { "type": "number" },
        "tags": { "type": "array" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase recording",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["PLACED", "SHIPPED", "DELIVERED", "CANCELLED"] },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Product review by a customer",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "Visit": {
      "title": "Visit",
      "description": "Daily visitor count",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "count": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Analytics tracking"
    }
  }
}
